{
  "name": "claude-code-local",
  "version": "2.1.89",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun --preload ./shims/preload.ts src/entrypoints/cli.tsx",
    "dev": "bun --preload ./shims/preload.ts --watch src/entrypoints/cli.tsx",
    "build": "bun run ./scripts/build.ts",
    "build:dev": "bun run ./scripts/build.ts --dev",
    "compile": "bun run ./scripts/build.ts --compile",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "smoke": "bun --preload ./shims/preload.ts src/entrypoints/cli.tsx --version && ANTHROPIC_API_KEY=sk-ant-smoke ./start.sh --version >/dev/null",
    "verify": "bun run build:dev && bun test && bun run smoke"
  },
