# 复制为 .env 并填入你的配置
# cp .env.example .env

# === API 密钥（必填）===
ANTHROPIC_API_KEY="your-api-key-here"

# === 第三方代理（可选）===
# 支持 OpenAI 兼容格式的 API 端点（如 DashScope, OneAPI, LiteLLM 等）
# 注意：不需要手动带 /v1，start.sh 会自动规范化
# 当 BASE_URL 不包含 anthropic.com 时，自动启用 OpenAI 兼容模式
ANTHROPIC_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode"
# DISABLE_PROMPT_CACHING=1
# DISABLE_INTERLEAVED_THINKING=1
# CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1

# === 模型选择（可选）===
ANTHROPIC_MODEL="qwen3-coder-next"

# === 界面语言（可选）===
# 例如：zh-CN / en-US
CLAUDE_CODE_LOCALE="zh-CN"
